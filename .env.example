# Google Sheet ID (from the sheet URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=

# Path to your Chrome user profile directory so WhatsApp Web stays logged in
# Windows example: C:\Users\YourName\AppData\Local\Google\Chrome\User Data
# Mac example:     /Users/YourName/Library/Application Support/Google/Chrome
CHROME_PROFILE_PATH=

# Number of days to keep finished rows in the Sheet before weekly cleanup deletes them.
# Only SENT, DUPLICATE, and FAILED rows are deleted. PENDING rows are kept regardless.
# Cleanup runs every Sunday at 03:00 container-local time.
CLEANUP_DAYS=7

# ---------------------------------------------------------------------------
# Alerts (email + optional SMS)
# ---------------------------------------------------------------------------
# Email alerts fire when WhatsApp sends fail repeatedly, the Sheet becomes
# unreachable, or weekly cleanup crashes. SMS is sent only for CRITICAL alerts
# (session dead, QR re-scan required).
#
# Gmail app password setup:
#   1. Google account -> Security -> 2-Step Verification -> App passwords
#   2. Create a password named "job-forwarder" (16 chars, no spaces in the value)
#   3. Paste below as SMTP_PASSWORD
#
# Leave any var blank to disable alerts entirely (silent no-op).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=
ALERT_EMAIL_TO=your@gmail.com

# Carrier email-to-SMS gateway for critical alerts. Leave blank to disable SMS.
# Format: <10-digit-number>@<carrier-gateway>
# Common gateways:
#   T-Mobile:    <number>@tmomail.net
#   AT&T:        <number>@txt.att.net
#   Verizon:     <number>@vtext.com
#   Sprint:      <number>@messaging.sprintpcs.com
#   Google Fi:   <number>@msg.fi.google.com
#   US Cellular: <number>@email.uscc.net
ALERT_SMS_TO=

# Number of consecutive WhatsApp send failures before escalating.
# Ladder: at THRESHOLD -> email warning,
#         at THRESHOLD*2 -> driver restart + email,
#         at THRESHOLD*3 -> CRITICAL email + SMS (session dead).
FAILURE_THRESHOLD=3

# Minimum seconds between repeats of the same alert key (default 1 hour).
ALERT_THROTTLE_SECONDS=3600
